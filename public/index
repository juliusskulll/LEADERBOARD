<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fortnite Tracker Stats</title>
<style>
  body {font-family: Arial, sans-serif; background: #1a1a1a; color: #fff; text-align:center; padding: 40px;}
  .stat {margin: 15px 0; font-size: 1.4em;}
  input {padding: 10px; width: 200px; font-size: 1em;}
  button {padding: 10px 15px; font-size: 1em; cursor:pointer;}
  #loading {display:none;}
</style>
</head>
<body>

<h1>Fortnite Stats Viewer</h1>
<p>Enter an Epic Games username:</p>

<input type="text" id="username" placeholder="hazelnutspread" value="hazelnutspread">
<button onclick="fetchStats()">Get Stats</button>

<div id="loading">⏳ Fetching stats...</div>

<div id="results" style="display:none;">
  <div class="stat"><strong>K/D:</strong> <span id="kd"></span></div>
  <div class="stat"><strong>Wins:</strong> <span id="wins"></span></div>
  <div class="stat"><strong>Matches:</strong> <span id="matches"></span></div>
  <div class="stat"><strong>Top 5s:</strong> <span id="top5"></span></div>
</div>

<script>
async function fetchStats() {
  // Get the username
  const user = document.getElementById('username').value.trim();
  if (!user) return alert('Please enter a username');

  document.getElementById('loading').style.display = 'block';
  document.getElementById('results').style.display = 'none';

  try {
    const url = `https://api.allorigins.win/raw?url=https://fortnitetracker.com/showdown/epicgames_${encodeURIComponent(user)}`;
    const response = await fetch(url);
    const text = await response.text();

    // Parse the scraped HTML
    const parser = new DOMParser();
    const htmlDoc = parser.parseFromString(text, 'text/html');

    // Example selectors: These might change if fortnitetracker updates their layout
    const kd = htmlDoc.querySelector('.trn-defstat__value:contains("K/D")')?.textContent || 'N/A';
    const wins = htmlDoc.querySelector('.trn-defstat__value:contains("Wins")')?.textContent || 'N/A';
    const matches = htmlDoc.querySelector('.trn-defstat__value:contains("Matches")')?.textContent || 'N/A';
    const top5 = htmlDoc.querySelector('.trn-defstat__value:contains("Top 5")')?.textContent || 'N/A';

    // Output to DOM
    document.getElementById('kd').textContent = kd;
    document.getElementById('wins').textContent = wins;
    document.getElementById('matches').textContent = matches;
    document.getElementById('top5').textContent = top5;

    document.getElementById('results').style.display = 'block';
  } catch (error) {
    alert('Error fetching stats — maybe FortniteTracker layout changed.');
    console.error(error);
  } finally {
    document.getElementById('loading').style.display = 'none';
  }
}
</script>

</body>
</html>
